# ── Gateway ──────────────────────────────────────────────────────────────
PORT=4000
# fail-open: if metering/DB is down, requests still pass to the provider.
# fail-closed: block requests when controls cannot be evaluated.
FAIL_MODE=open

# Master key that seals provider credentials at rest.
# Generate one with:  openssl rand -base64 32
MASTER_ENCRYPTION_KEY=change-me-generate-a-32-byte-key

# Upstream providers the gateway forwards to. Defaults to the real APIs.
# (Distinct from ANTHROPIC_BASE_URL, which is what a CLIENT like Claude Code
#  sets to point AT this gateway.) Override to a local mock for development:
#   UPSTREAM_ANTHROPIC_URL=http://localhost:8787
UPSTREAM_ANTHROPIC_URL=https://api.anthropic.com
UPSTREAM_OPENAI_URL=https://api.openai.com

# Control-plane admin API token. If set, all /api/admin/* calls must present it
# (Authorization: Bearer <token> or x-admin-token). Unset = open (dev/first-boot).
# ADMIN_TOKEN=change-me-admin-token

# ── Data governance (Phase 2) ────────────────────────────────────────────
# T1 secrets scan: detect API keys / tokens / private keys in a request BEFORE
# it leaves the perimeter for a provider. Privacy: only the CATEGORY is recorded,
# never the matched value.
#   GOVERNANCE_ENABLED  on|off      (default on)
#   GOVERNANCE_MODE     alert|block (default alert)
#     alert → detect + record + forward (zero added latency, visibility only)
#     block → reject with 451 before the request reaches the provider
GOVERNANCE_ENABLED=on
GOVERNANCE_MODE=alert
# Alert→block feedback loop: categories listed here ALWAYS block, even while the
# global mode stays `alert`. Run in alert, watch each category's false-positive
# rate on the dashboard, then promote the high-confidence ones one at a time.
# Categories: aws_credentials, private_key, github_token, provider_api_key,
# google_api_key, slack_token, stripe_key, jwt, generic_secret
# GOVERNANCE_BLOCK_CATEGORIES=aws_credentials,private_key

# ── Provider adapters (Phase 2) ──────────────────────────────────────────
# Conduit can sit in front of AWS Bedrock or Azure OpenAI instead of the direct
# APIs — configure that credential (via /setup or the admin API) and the org
# routes through it with no client change:
#   Bedrock: provider="bedrock", key="<accessKeyId>:<secretAccessKey>",
#            baseUrl="<region e.g. us-east-1>" (non-streaming /invoke only).
#   Azure:   provider="azure",   key="<azure-api-key>",
#            baseUrl="https://<resource>.openai.azure.com" (deployment = model).
# AWS_REGION=us-east-1
# AZURE_OPENAI_API_VERSION=2024-10-21

# ── Dashboard auth (control-plane UI) ─────────────────────────────────────
# If set, the browser dashboard requires this password (a hashed cookie is
# issued; the password itself is never stored). Unset = open (dev/first-boot).
# Production installs MUST set it. DASHBOARD_SECRET salts the cookie token.
# DASHBOARD_PASSWORD=change-me-dashboard-password
# DASHBOARD_SECRET=change-me-random-salt

# ── Postgres (OLTP — config, identity, budgets) ──────────────────────────
POSTGRES_URL=postgres://finops:finops@localhost:5432/finops

# ── ClickHouse (analytics — usage events) ────────────────────────────────
CLICKHOUSE_URL=http://finops:finops@localhost:8123/finops

# Metering buffer: flush usage events to ClickHouse in batches of this size, or
# every METER_FLUSH_MS, whichever comes first. Never on the request hot path.
METER_BATCH_SIZE=100
METER_FLUSH_MS=2000

# ── Redis (cache, rate limits, live budget counters) ─────────────────────
REDIS_URL=redis://localhost:6379

# Exact-match response cache (M6). Conservative: only byte-identical normalized
# requests share a cached response. Disable with CACHE_ENABLED=false.
CACHE_ENABLED=true
CACHE_TTL_S=3600

# Budget threshold alerts (50/80/100%). Optional webhook for delivery; alerts
# are always logged. Leave unset to log-only.
# ALERT_WEBHOOK_URL=https://hooks.example.com/finops
