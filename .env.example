# ── Gateway ──────────────────────────────────────────────────────────────
PORT=4000
# fail-open: if metering/DB is down, requests still pass to the provider.
# fail-closed: block requests when controls cannot be evaluated.
FAIL_MODE=open

# Master key that seals provider credentials at rest.
# Generate one with:  openssl rand -base64 32
MASTER_ENCRYPTION_KEY=change-me-generate-a-32-byte-key

# Upstream providers the gateway forwards to. Defaults to the real APIs.
# (Distinct from ANTHROPIC_BASE_URL, which is what a CLIENT like Claude Code
#  sets to point AT this gateway.) Override to a local mock for development:
#   UPSTREAM_ANTHROPIC_URL=http://localhost:8787
UPSTREAM_ANTHROPIC_URL=https://api.anthropic.com
UPSTREAM_OPENAI_URL=https://api.openai.com

# Control-plane admin API token. If set, all /api/admin/* calls must present it
# (Authorization: Bearer <token> or x-admin-token). Unset = open (dev/first-boot).
# ADMIN_TOKEN=change-me-admin-token

# ── Postgres (OLTP — config, identity, budgets) ──────────────────────────
POSTGRES_URL=postgres://finops:finops@localhost:5432/finops

# ── ClickHouse (analytics — usage events) ────────────────────────────────
CLICKHOUSE_URL=http://finops:finops@localhost:8123/finops

# Metering buffer: flush usage events to ClickHouse in batches of this size, or
# every METER_FLUSH_MS, whichever comes first. Never on the request hot path.
METER_BATCH_SIZE=100
METER_FLUSH_MS=2000

# ── Redis (cache, rate limits, live budget counters) ─────────────────────
REDIS_URL=redis://localhost:6379

# Exact-match response cache (M6). Conservative: only byte-identical normalized
# requests share a cached response. Disable with CACHE_ENABLED=false.
CACHE_ENABLED=true
CACHE_TTL_S=3600

# Budget threshold alerts (50/80/100%). Optional webhook for delivery; alerts
# are always logged. Leave unset to log-only.
# ALERT_WEBHOOK_URL=https://hooks.example.com/finops
